# ── Analytics (Vercel env vars — prefix VITE_ for client-side access) ──────────
# Google Tag Manager — recommended for ad tracking (GA4, Meta Pixel, etc. live inside GTM)
# Get from: https://tagmanager.google.com → Admin → Container ID
VITE_GTM_ID=

# Google Analytics 4 — only used if GTM is NOT set
# Get from: https://analytics.google.com → Admin → Data Streams → Measurement ID
VITE_GA_MEASUREMENT_ID=

# Meta Pixel — add your Facebook Ads pixel ID here
VITE_META_PIXEL_ID=

# GoHighLevel (LeadConnector) — Hybrid Funding sub-account
# Server-only. Never expose to the client.
GHL_PIT_TOKEN=
GHL_LOCATION_ID=wAgobr9TOihDZxQ2G3a5
