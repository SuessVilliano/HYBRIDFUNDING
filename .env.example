# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/hybridfunding

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# ── Stream Video (Trader Battles) ─────────────────────────────────────────────
# Get your keys at https://getstream.io → Create App → Video & Audio
# The public key is exposed to the browser; the secret stays server-side only.
VITE_STREAM_KEY=your_stream_api_key_here
STREAM_KEY=your_stream_api_key_here
STREAM_SECRET=your_stream_api_secret_here

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string
