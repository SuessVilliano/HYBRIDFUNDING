{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "battles.hybridfunding.co" }],
      "destination": "/battles/lobby",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/battles/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
